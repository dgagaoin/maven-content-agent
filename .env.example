# Maven — local environment
#
# LAYERED LOADING (first-set wins; process env trumps all):
#   1. agents/maven/.env             ← this file (per-agent overrides)
#   2. $SHARED_ENV_PATH              ← optional explicit shared path
#   3. ../../astraea/.env            ← shared LLM keys + Telegram allow-list + Google creds
#   4. ../moneypenny/.env            ← Moneypenny's reused values (fallback)
#
# Set ONLY Maven-specific values here. ANTHROPIC_API_KEY, ALLOWED_TELEGRAM_IDS, and the
# shared OAuth token path inherit from astraea/.env — DO NOT duplicate them here.

# ── Maven-specific (must be set here) ─────────────────────────────────────────
# Use the NAMESPACED token. Do NOT set TELEGRAM_BOT_TOKEN — that one belongs to Astraea
# and is inherited from astraea/.env. Setting it here would make Maven poll Astraea's bot.
MAVEN_TELEGRAM_BOT_TOKEN=                 # NEW bot from BotFather (e.g. @MavenAPISBot)
MAVEN_DRIVE_FOLDER_ID=                    # Maven's Drive folder (shared with the OAuth user)
MAVEN_CONTENT_CALENDAR_SHEET_ID=          # optional MVP-2; can be created later

# ── Optional Maven overrides ──────────────────────────────────────────────────
# ANTHROPIC_MODEL=claude-sonnet-4-6
# MAVEN_DEFAULT_CHANNELS=LinkedIn,Website,Email
# DATA_DIR=./data
# LOG_LEVEL=info
# ENVIRONMENT=development
# USE_MOCK_ADAPTERS=false
